# Copy this file to .env and fill in all values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (get from supabase.com → project → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT (generate a random string, e.g.: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Stripe (get from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...

# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_1=price_...    # CHF 29 — 1 token
STRIPE_PRICE_5=price_...    # CHF 49 — 5 tokens
STRIPE_PRICE_50=price_...   # CHF 149 — 50 tokens

# Frontend origin (for CORS — your Vercel URL)
ALLOWED_ORIGIN=https://websiterevive-ten.vercel.app
