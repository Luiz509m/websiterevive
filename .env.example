# Copy this file to .env and fill in all values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (get from supabase.com → project → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT (generate a random string, e.g.: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Stripe (get from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...

# Stripe Price IDs (create in Stripe dashboard → Products, copy the price_... id)
STRIPE_PRICE_1=price_...           # Self-Service 1 Token  — CHF 49  (one-time)
STRIPE_PRICE_5=price_...           # Self-Service 5 Tokens — CHF 149 (one-time)
STRIPE_PRICE_COMPLETE=price_...    # Create + Host         — CHF 29/month (recurring)
STRIPE_HOSTING_PRICE_ID=price_...  # Hosting Only          — CHF 12/month (recurring)

# Frontend origin (for CORS — your Vercel URL)
ALLOWED_ORIGIN=https://websiterevive-ten.vercel.app

# Web3Forms (get free key at web3forms.com — one key works for all generated sites)
WEB3FORMS_KEY=your-web3forms-access-key
